# Database
# For local dev with Docker PostgreSQL:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lead_portal

# For production on Vercel (Neon Postgres - Serverless PostgreSQL):
# 1. Go to https://neon.tech and sign up (free tier available)
# 2. Create a project → copy the connection string
# 3. It will look something like:
# DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# Alternative options:
# - Supabase: https://supabase.com (free tier with PostgreSQL)
# - AWS RDS, Google Cloud SQL, etc.
# - Any PostgreSQL provider works, just paste the connection string here
#
# Set this as an environment variable in Vercel:
#   vercel env add DATABASE_URL
# Or via Vercel Dashboard → Project → Settings → Environment Variables

# HubSpot CRM (optional - leave empty to disable)
# Get this from HubSpot Developer account → Apps → Private Apps → Create access token
HUBSPOT_ACCESS_TOKEN=

# Port (local dev only)
PORT=3000