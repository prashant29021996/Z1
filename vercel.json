{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/api/leads", "dest": "/api/leads.js" },
    { "src": "/api/stats", "dest": "/api/stats.js" },
    { "src": "/api/hubspot", "dest": "/api/hubspot.js" },
    { "src": "/static/(.*)", "dest": "/public/$1" }
  ],
  "env": {
    "VERCEL": "1"
  }
}